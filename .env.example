# Kopie dieser Datei als .env.local anlegen und Werte eintragen.

# API-Key von https://resend.com (API Keys → Create API Key)
RESEND_API_KEY=

# Empfänger der Angebotsanfragen aus dem Konfigurator
ANGEBOT_EMAIL=

# Optionaler Absender (ohne verifizierte Domain: onboarding@resend.dev lassen)
# ANGEBOT_FROM=Loihl Konfigurator <onboarding@resend.dev>
